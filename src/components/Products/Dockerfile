# ==============================================================================
# STAGE 1: Compiling the Client Assets
# ==============================================================================
FROM node:22-alpine3.20 AS compiler

WORKDIR /usr/src/app

COPY package.json package-lock.json ./
RUN npm ci --is-frozen-lockfile

COPY . .
# Generates a highly optimized, minified 'dist' or 'build' folder
RUN npm run build

# ==============================================================================
# STAGE 2: Ultra-Fast Static Asset Delivery (Nginx Edge)
# ==============================================================================
FROM nginx:1.27-alpine

# Copy custom enterprise Nginx configurations (handling routing, gzip, security headers)
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy compiled static assets straight into the server root
COPY --from=compiler /usr/src/app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
